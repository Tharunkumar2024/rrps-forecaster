# Database (SQLite for local dev, swap to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./rrps_dev.db
DATABASE_URL_SYNC=sqlite:///./rrps_dev.db

# Production PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rrps_db
# DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/rrps_db

# App
APP_NAME=RRPS Forecaster
APP_ENV=development
DEBUG=true
